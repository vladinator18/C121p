generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Artwork {
  id        Int      @id @default(autoincrement())
  artist    String   // e.g., "Pablo Picasso"
  title     String   // e.g., "Cubism"
  likes     Int      @default(0)
  createdAt DateTime @default(now())
}